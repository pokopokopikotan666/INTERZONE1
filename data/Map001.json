{"id":1,"name":"intro","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":0,"tileId":0},"list":[{"code":205,"indent":0,"parameters":[-1,{"list":[{"code":39,"indent":null},{"code":0}],"repeat":false,"skippable":false,"wait":true}]},{"code":505,"indent":0,"parameters":[{"code":39,"indent":null}]},{"code":201,"indent":0,"parameters":[0,1,11,2,0,0]},{"code":111,"indent":0,"parameters":[4,1,0]},{"code":205,"indent":1,"parameters":[0,{"list":[{"code":41,"parameters":["$Male_sit",0],"indent":null},{"code":0}],"repeat":false,"skippable":false,"wait":true}]},{"code":505,"indent":1,"parameters":[{"code":41,"parameters":["$Male_sit",0],"indent":null}]},{"code":0,"indent":1,"parameters":[]},{"code":411,"indent":0,"parameters":[]},{"code":205,"indent":1,"parameters":[0,{"list":[{"code":41,"parameters":["$Female_sit",0],"indent":null},{"code":0}],"repeat":false,"skippable":false,"wait":true}]},{"code":505,"indent":1,"parameters":[{"code":41,"parameters":["$Female_sit",0],"indent":null}]},{"code":0,"indent":1,"parameters":[]},{"code":412,"indent":0,"parameters":[]},{"code":230,"indent":0,"parameters":[10]},{"code":102,"indent":0,"parameters":[["Ver Introducción","Saltar Introducción"],1,0,2,0]},{"code":402,"indent":0,"parameters":[0,"Ver Introducción"]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["Tus ojos se abren con lentitud, permitiendo que un hilo de luz reanime tus recuerdos. Voces, sonidos e imágenes se agitan violentamente en tu mente, como fragmentos de un cristal roto. ¿Cómo has terminado aquí?"]},{"code":401,"indent":1,"parameters":["Todo comenzó con tu labor como agente del FBI en la división de narcóticos. Tu equipo seguía el rastro del \"ergot\", un hongo del que brotaba una nueva y devastadora droga alucinógena. Los informes eran escalofriantes: los consumidores caían en un letargo catatónico durante horas para despertar sumergidos en ataques de pánico o brotes psicóticos. En el peor de los casos, el corazón simplemente se rendía, dejando tras de sí un cadáver con el rostro congelado en una mueca de puro horror."]},{"code":401,"indent":1,"parameters":["Tras una búsqueda extenuante, localizaron un punto de venta. Durante la redada, en medio del caos de los gritos y la confusión, uno de los adictos te sopló el polvo de la droga directamente a los ojos y la boca. El pánico te invadió y tu primer instinto fue huir hacia un hospital, pero el camino se volvió una pesadilla: figuras imposibles acechaban en la periferia de tu visión y sonidos distorsionados taladraban tus oídos. Desesperado y con el corazón martilleando contra el pecho, cambiaste de rumbo hacia tu hogar, buscando el refugio de tu esposa."]},{"code":401,"indent":1,"parameters":["Sin embargo, al cruzar el umbral, la realidad se quebró en una escena digna de la más salvaje pesadilla kafkiana: una cucaracha de proporciones humanas te esperaba sentada en el sillón de la sala. El estupor te obligó a desenfundar tu arma de servicio, pero el terror absoluto fue más fuerte que tu voluntad y el mundo se fundió a negro."]},{"code":101,"indent":1,"parameters":["",0,0,2]},{"code":401,"indent":1,"parameters":["Así llegaste a este lugar. Y allí, a pocos pasos, la misma alimaña pesadillesca te observa en silencio. Parece que este mal sueño apenas comienza."]},{"code":0,"indent":1,"parameters":[]},{"code":402,"indent":0,"parameters":[1,"Saltar Introducción"]},{"code":0,"indent":1,"parameters":[]},{"code":404,"indent":0,"parameters":[]},{"code":230,"indent":0,"parameters":[40]},{"code":111,"indent":0,"parameters":[4,1,0]},{"code":205,"indent":1,"parameters":[0,{"list":[{"code":41,"parameters":["$Male",0],"indent":null},{"code":0}],"repeat":false,"skippable":false,"wait":true}]},{"code":505,"indent":1,"parameters":[{"code":41,"parameters":["$Male",0],"indent":null}]},{"code":0,"indent":1,"parameters":[]},{"code":411,"indent":0,"parameters":[]},{"code":205,"indent":1,"parameters":[0,{"list":[{"code":41,"parameters":["$Female",0],"indent":null},{"code":0}],"repeat":false,"skippable":false,"wait":true}]},{"code":505,"indent":1,"parameters":[{"code":41,"parameters":["$Female",0],"indent":null}]},{"code":0,"indent":1,"parameters":[]},{"code":412,"indent":0,"parameters":[]},{"code":205,"indent":0,"parameters":[-1,{"list":[{"code":40,"indent":null},{"code":0}],"repeat":false,"skippable":false,"wait":true}]},{"code":505,"indent":0,"parameters":[{"code":40,"indent":null}]},{"code":121,"indent":0,"parameters":[1,1,0]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":3,"walkAnime":true},{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":true,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":0,"tileId":0},"list":[{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":0,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":11,"y":2},
{"id":2,"name":"EV002","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":true,"image":{"tileId":0,"characterName":"$commissionrecruiter","direction":2,"pattern":0,"characterIndex":0},"list":[{"code":101,"indent":0,"parameters":["commissionrecruiter",0,1,2]},{"code":401,"indent":0,"parameters":["Buenas, agente. Es un gusto finalmente poder ponerme en contacto con usted. Qué desafortunado que tenga que ser bajo estas circunstancias. Intenté comunicarme con usted en su casa, pero parece que mi visita lo tomó por sorpresa. En fin, seré breve; ambos somos conscientes de lo valioso que es el tiempo, ¿verdad?"]},{"code":401,"indent":0,"parameters":["Verá, soy miembro de una organización que se encarga de resguardar un lugar que existe justo en medio del velo de su realidad. Se llama 'Interzona', y la manera más sencilla de acceder es por medio de la droga que le fue suministrada. Si lo que está escuchando le parece extraño, lo que sigue le volará la cabeza: su esposa ha estado merodeando por el changarro junto con su grupo de amigotes, y le está provocando varios problemas y dolores de cabeza a mi jefe."]},{"code":401,"indent":0,"parameters":["Seré honesto: inicialmente pensábamos simplemente deshacernos de ella, pero ha probado ser muy problemática —y cara— para nuestros asesinos. Por ello, hemos optado por la decisión más sensata: contactarlo directamente para que la convenza de retirarse pacíficamente y olvidarse del asunto. No pretendo que comprenda todo de inmediato pero, como dije, el tiempo se acaba e Interzona no es un lugar adecuado para que una dama tan delicada deambule. De aceptar, le brindaremos todo el apoyo posible una vez que esté dentro. Así que, ¿qué me dice? ¿Aceptaría formar parte de nuestra organización?"]},{"code":102,"indent":0,"parameters":[["Si, de acuerdo.","No, esto no tiene ningún sentido."],1,0,2,1]},{"code":402,"indent":0,"parameters":[0,"Si, de acuerdo."]},{"code":101,"indent":1,"parameters":["commissionrecruiter",0,1,2]},{"code":401,"indent":1,"parameters":["Fantastico, me alegro de tenerlo a bordo agente. "]},{"code":401,"indent":1,"parameters":["Por favor, refiera su atención hacia la entrada que abriré para"]},{"code":401,"indent":1,"parameters":["usted y cuidado con la cabeza."]},{"code":121,"indent":1,"parameters":[2,2,0]},{"code":123,"indent":1,"parameters":["A",0]},{"code":0,"indent":1,"parameters":[]},{"code":402,"indent":0,"parameters":[1,"No, esto no tiene ningún sentido."]},{"code":101,"indent":1,"parameters":["commissionrecruiter",0,1,2]},{"code":401,"indent":1,"parameters":["Bueno, es ciertamente desafortunado. Personalmente considero"]},{"code":401,"indent":1,"parameters":["desagradable aquel que no ve por el bienestar de su esposa. "]},{"code":401,"indent":1,"parameters":["Le deseo la mejor de las suertes, agente."]},{"code":0,"indent":1,"parameters":[]},{"code":404,"indent":0,"parameters":[]},{"code":123,"indent":0,"parameters":["A",0]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":true,"through":false,"trigger":0,"walkAnime":false},{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":true,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":true,"image":{"tileId":0,"characterName":"$commissionrecruiter","direction":2,"pattern":0,"characterIndex":0},"list":[{"code":111,"indent":0,"parameters":[2,"A",0]},{"code":0,"indent":1,"parameters":[]},{"code":412,"indent":0,"parameters":[]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"c